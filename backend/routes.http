@id = 0
@hostname = localhost
@port = 3000

### get produtos
GET http://localhost:3000/api/produtos/{{id}}

### POST produtos
# @name createProduct
# @prompt description
# @prompt price
POST http://localhost:3000/api/produtos/
Content-Type: application/json

{
  "description": "{{description}}",
  "price": {{price}}
}

###

@id = {{createProduct.response.body.$.produto.$.id}}

###
# @prompt username
PUT http://localhost:3000/api/produtos/{{id}}
Content-Type: application/json

{
  "description": "{{username}}",
  "price": 33
}

###
DELETE http://localhost:3000/api/produtos/{{id}}